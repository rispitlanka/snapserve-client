# Frontend Environment Variables

# Copy this to .env.local (local development)
# and configure .env.production for production deployment

# ============================================
# Development (Local)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:5000

# ============================================
# Production (Render + Vercel)
# ============================================
# On Vercel dashboard, set:
# NEXT_PUBLIC_API_URL=https://snapserve-backend.onrender.com

# ============================================
# Notes:
# - The NEXT_PUBLIC_ prefix makes it accessible in browser
# - Keep this file in .gitignore
# - Create .env.local for local dev
# - Create .env.production for production
# - On Vercel: Settings → Environment Variables
# ============================================
